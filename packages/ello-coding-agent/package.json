{
  "name": "@ello/coding-agent",
  "version": "0.1.0",
  "description": "Coding-agent product layer for ello",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ello": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && cp -R src/config/templates dist/config/templates && cp -R src/context/prompts dist/context/prompts && cp -R src/skills/bundled dist/skills/bundled && cp -R src/agents/bundled dist/agents/bundled && cp -R src/storage/migrations dist/storage/migrations && chmod +x dist/cli.js",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ello/agent": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "ink": "^6.5.0",
    "ink-text-input": "^6.0.0",
    "nunjucks": "^3.2.4",
    "react": "^19.2.3",
    "tinyglobby": "^0.2.17",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/nunjucks": "^3.2.6",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "drizzle-kit": "^0.31.10",
    "ink-testing-library": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.15"
  }
}
