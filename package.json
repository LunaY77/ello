  },
  "devDependencies": {
    "@ello/coding-agent": "workspace:*",
    "@ello/tui": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "eslint": "^10.5.0",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.8.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.15"
  }
}
