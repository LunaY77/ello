{
  "name": "ello-ts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript workspace for ello",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "format": "prettier --write .",
    "lint": "eslint .",
